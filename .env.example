PUBLIC_APP_URL=https://your-formed-by-elias-domain.vercel.app
APP_NAME=Formed
COACH_NAME=Elias
CALENDAR_NAME=Elias
TIMEZONE=America/Chicago
OPENAI_MODEL=gpt-5.2
OPENAI_API_KEY=

# Create this from Strava's API settings page.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Create these in Supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Generate with: openssl rand -base64 32
APP_SECRET=
CALENDAR_TOKEN=
STRAVA_WEBHOOK_VERIFY_TOKEN=
STRAVA_WEBHOOK_SIGNING_SECRET=

# Optional after first Strava connect, if you want to lock sync/feed to one athlete id.
ATHLETE_ID=

# Calendar timing defaults.
WEEKDAY_START=05:30
WEEKDAY_DONE_BY=07:00
WEEKEND_START=05:45
WEEKEND_DONE_BY=07:30
